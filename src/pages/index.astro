---
import { getEntry, render } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const diaryEntry = await getEntry('home', 'diary');
const { Content } = diaryEntry ? await render(diaryEntry) : { Content: null };
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-background text-foreground transition-colors duration-300 flex flex-col min-h-dvh">
		<Header />
		<main class="flex-grow flex flex-col justify-center px-4 py-12">
			<div class="prose prose-slate dark:prose-invert lg:prose-xl mx-auto w-full">
				<section class="space-y-6 text-center sm:text-left">
					<h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-8">
						Senior Frontend Engineer & Testing Automation Specialist
					</h1>
					<p class="text-lg text-muted-foreground leading-relaxed">
						我是 Yusong，一名專注於高效能、可擴展性及自動化測試的資深前端工程師。我致力於透過卓越的架構設計與自動化流程，打造極致的開發體驗與穩定可靠的 Web 應用。
					</p>
				</section>

				{Content && (
					<section class="mt-12 p-6 bg-muted/30 rounded-2xl border border-muted">
						<div class="text-sm font-bold mb-4 uppercase tracking-wider text-muted-foreground">Diary</div>
						<div class="italic text-muted-foreground">
							<Content />
						</div>
					</section>
				)}

				<section class="mt-12 text-center sm:text-left">
					<p class="italic text-muted-foreground text-sm">
						"追求卓越不只是目標，而是一種持續最佳化的開發習慣。"
					</p>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>
